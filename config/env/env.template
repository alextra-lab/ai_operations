# AI Operations Platform (AIOP) Environment Configuration Template
# Copy this file to .env and fill in your values

CONFIG_SCHEMA_VERSION=2026.02.18
# CORE CONFIGURATION

# Environment
ENV=development
SERVICE_VERSION=1.0.0
TESTING=0
DEVELOPMENT=0

# DATABASE CONFIGURATION

# PostgreSQL Database
POSTGRES_USER=user
POSTGRES_PASSWORD=password
POSTGRES_DB=aio
POSTGRES_HOST=postgres-db
POSTGRES_PORT=5432
POSTGRES_SSL_MODE=
POSTGRES_MAX_CONNECTIONS=20
POSTGRES_CONNECTION_TIMEOUT=30
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_RECYCLE=3600
DB_POOL_PRE_PING=true

# Note: literal inter-container URL (shell variable expansion in xargs does not work for composed URLs)
DATABASE_URL=postgresql+psycopg://user:password@postgres-db:5432/aio

# VECTOR DATABASE CONFIGURATION

# Qdrant Vector Database
QDRANT_HOST=vector-db
QDRANT_PORT=6333
QDRANT_URL=http://vector-db:6333
QDRANT_API_KEY=
QDRANT_PREFER_GRPC=false
QDRANT_TIMEOUT=10.0
QDRANT_COLLECTION=documents
QDRANT_VECTOR_SIZE=384
QDRANT_DISTANCE=COSINE
QDRANT_HNSW_M=16
QDRANT_HNSW_EF_CONSTRUCT=100
QDRANT_HNSW_EF_SEARCH=128
QDRANT_DEFAULT_LIMIT=10
QDRANT_DEFAULT_OFFSET=0

# Inference Gateway Configuration (P1-T1 - Nov 2025)
GATEWAY_HOST=0.0.0.0
GATEWAY_PORT=8002
GATEWAY_DEBUG=true
GATEWAY_ENABLE_CORS=true
GATEWAY_CORS_ORIGINS=*

# Redis Configuration (P2-T4 - Nov 2025)
REDIS_URL=redis://redis-cache:6379
REDIS_ENABLED=true
REDIS_MAX_CONNECTIONS=50
REDIS_SOCKET_TIMEOUT=5
REDIS_SOCKET_CONNECT_TIMEOUT=5

# AUTHENTICATION CONFIGURATION

# JWT Authentication
JWT_SECRET=your-secure-secret-key-here-minimum-32-characters
# Tool Secrets Encryption Key (for tool secret storage - use strong key in production)
TOOL_SECRETS_KEY=your-tool-secrets-encryption-key-minimum-32-characters-for-aes256
JWT_ALGORITHM=HS256
JWT_ISSUER=ai-operations-platform
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# LOGGING CONFIGURATION

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_ENABLE_STRUCTURED=true
LOG_ENABLE_REQUEST_ID=true
LOG_VERBOSE=false

# Secure Logging (v1 - Configuration Flag)
# Controls whether sensitive data (queries, responses, session IDs) are redacted in logs
# CRITICAL: Set REDACT_LOGS=true in production to prevent security breach
REDACT_LOGS=false  # Development default: disabled. Production: MUST be 'true'
LOG_REDACTION_LEVEL=partial  # none|partial|full
#   - none: No redaction (dev/test only)
#   - partial: Redact content, show length+hash (recommended for production)
#   - full: Redact everything except metadata

# Frontend Logging (Angular)
# Controls verbose request/response logging in the UI
FRONTEND_VERBOSE_LOGGING=false

# OPENTELEMETRY CONFIGURATION

# OpenTelemetry (Optional)
OTEL_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=aio
OTEL_SERVICE_VERSION=1.0.0

# EMBEDDING SERVICE CONFIGURATION

# Embedding Service
EMBEDDING_HOST=0.0.0.0
EMBEDDING_PORT=8000
EMBEDDING_DEBUG=false
EMBEDDING_ENABLE_CORS=true
EMBEDDING_CORS_ORIGINS=*
EMBEDDING_MODEL=all-minilm-l6-v2
EMBEDDING_DIMENSIONS=384
EMBEDDING_MODEL_CACHE_DIR=/opt/models
EMBEDDING_ENABLE_MODEL_CACHING=true
EMBEDDING_BATCH_SIZE=32
EMBEDDING_CLIENT_TIMEOUT_SECONDS=30
EMBEDDING_CLIENT_MAX_RETRIES=3
EMBEDDING_SERVICE_CLIENT_API_KEY=

# Constructed Service URL
EMBEDDING_SERVICE_URL=http://embedding-service:8000


# INFERENCE / LLM PROVIDERS
# LLM providers (base URL + API key) are configured in the inference-gateway
# (Provider Management / gateway_providers table), NOT here. The orchestrator and other
# services reach LLMs only through the gateway. There are no public/remote defaults.

# Optional API key for an OpenAI-compatible *embedding* endpoint, used only once such an
# endpoint is explicitly brought online. No remote default; with no embedding endpoint and
# no local model files present, embedding is disabled.
OPENAI_API_KEY=

# MODEL REGISTRY & PRICING CONFIGURATION

# Default pricing for all models (per 1M tokens in USD)
# These defaults are used when model-specific pricing is not set in database
# Set to 0.0 if included in LLMaaS subscription or using local models
PRICING_DEFAULT_INPUT_PER_MILLION=0.0
PRICING_DEFAULT_OUTPUT_PER_MILLION=0.0

# For paid services, set actual costs:
# PRICING_DEFAULT_INPUT_PER_MILLION=0.50
# PRICING_DEFAULT_OUTPUT_PER_MILLION=2.00

# CORPUS SERVICE CONFIGURATION

# Corpus Service
CORPUS_HOST=0.0.0.0
CORPUS_PORT=8001
CORPUS_DEBUG=false
CORPUS_ENABLE_CORS=true
CORPUS_CORS_ORIGINS=*
CORPUS_EMBEDDING_SERVICE_TOKEN=
CORPUS_DOCUMENTS_PATH=/data/documents
CORPUS_TEMP_PATH=/data/tmp
CORPUS_CHUNK_SIZE=1000
CORPUS_CHUNK_OVERLAP=200
CORPUS_MAX_CHUNKS_PER_DOCUMENT=1000

# Constructed Service URL
CORPUS_SERVICE_URL=http://corpus-service:8001/api/v1

# LLM GUARD SERVICE CONFIGURATION

# LLM Guard Service.
# DISABLED BY DEFAULT (LLG-04 finale): the native scanners require models to be
# staged manually first (see src/llm_guard_svc/README.md) and the feature is not
# supported on the enterprise profile. Set to true ONLY after staging the models.
# This flag gates BOTH the service (scan vs pass-through) and the orchestrator
# integration (call the service vs skip).
LLM_GUARD_ENABLED=false
LLM_GUARD_HOST=0.0.0.0
LLM_GUARD_PORT=8081
LLM_GUARD_DEBUG=false
LLM_GUARD_ENABLE_CORS=true
LLM_GUARD_CORS_ORIGINS=*
LLM_GUARD_FAIL_FAST=false
LLM_GUARD_CACHE_ENABLED=true
LLM_GUARD_CACHE_MAX_SIZE=1000
LLM_GUARD_CACHE_TTL_SECONDS=3600
LLM_GUARD_MODELS_PATH=/app/models
LLM_GUARD_PII_MODEL_DIR=distilbert_finetuned_ai4privacy_v2
LLM_GUARD_GIBBERISH_MODEL_DIR=madhurjindal-autonlp-Gibberish-Detector-492513457
LLM_GUARD_LANGUAGE_MODEL_DIR=protectai-xlm-roberta-base-language-detection-onnx
LLM_GUARD_PROMPT_INJECTION_MODEL_DIR=protectai-deberta-v3-small-prompt-injection-v2
# GLiNER PII NER model (Apache-2.0, en+fr); used by the native anonymize engine only.
LLM_GUARD_GLINER_MODEL_DIR=gliner_multi_pii-v1
# Native PII (anonymize) thresholds, calibrated against the labelled PII set:
# Presidio patterns are high-precision (low threshold); GLiNER is high (real
# names/locations score >=0.94, common-noun false positives lower).
LLM_GUARD_PII_SCORE_THRESHOLD=0.3
LLM_GUARD_PII_GLINER_THRESHOLD=0.93

# Constructed Service URL
LLM_GUARD_SERVICE_URL=http://llm-guard-svc:8081

# ORCHESTRATOR SERVICE CONFIGURATION

# Orchestrator Service
ORCHESTRATOR_HOST=0.0.0.0
ORCHESTRATOR_PORT=8000
ORCHESTRATOR_DEBUG=false
ORCHESTRATOR_ENABLE_CORS=true
ORCHESTRATOR_CORS_ORIGINS=*
ENABLE_TRANSCRIPT_STORAGE=false

# Service Dependencies (references to other services)
CORPUS_SVC_URL=http://corpus-service:8001/api/v1
LLM_GUARD_SERVICE_URL=http://llm-guard-svc:8081

# STATELESS CORE V1 CONFIGURATION

# Edition Configuration
EDITION=core
STATEFUL_ENABLED=false

# Pipeline Configuration (P4-F11 Orchestrator Refactoring)
# Enable new Pipeline+Steps architecture (default: false for safety)
# Set to 'true' to use UseCaseRunner instead of legacy Orchestrator
# ADR-036: Orchestrator Pipeline Pattern
USECASE_RUNNER_ENABLED=false

# Provider Configuration
HISTORY_PROVIDER=none
EVIDENCE_SINK=none
CRYPTO_PROVIDER=none

# Feature Flags
ENABLE_EXPERT_CHUNKING=false
ENABLE_ADVANCED_ANALYTICS=false
RUN_MANIFEST_ENABLED=true
RUN_MANIFEST_FAIL_OPEN=true
ENABLE_PREFLIGHT_ANALYSIS=true
ENABLE_QUALITY_METRICS=true
ENABLE_TEST_HARNESS=true

# Chunking Configuration
CHUNKING_STRATEGY=fixed_token
CHUNK_SIZE=512
CHUNK_OVERLAP=50
MIN_CHUNK_SIZE=64
MAX_CHUNK_SIZE=2048

# Export Configuration
EXPORT_FORMATS=markdown,json
EXPORT_MAX_SIZE_MB=10
EXPORT_TTL_HOURS=24


# =============================================================================
# DASHBOARD HEALTH MONITORING
# =============================================================================

# Service health endpoints for SOC Dashboard real-time monitoring
# Format: JSON object mapping service name to health endpoint URL
# The orchestrator will poll these endpoints to display live service status
DASHBOARD_HEALTH_ENDPOINTS='{"Corpus": "http://corpus-service:8001/health", "Embedding": "http://embedding-service:8000/health", "Inference-Gateway": "http://inference-gateway:8002/health", "Orchestrator": "http://127.0.0.1:8000/health", "Qdrant": "http://vector-db:6333/healthz"}'

# =============================================================================
# DEPLOYMENT CONFIGURATION
# DEPLOYMENT CONFIGURATION

# Docker Compose Environment
COMPOSE_PROJECT_NAME=aio
COMPOSE_FILE=deploy/docker-compose.yml

# SECURITY NOTES

# IMPORTANT: Change these default values in production:
# - JWT_SECRET: Use a strong, random secret (minimum 32 characters)
# - POSTGRES_PASSWORD: Use a strong database password
# - OPENAI_API_KEY: Keep your API keys secure
# - QDRANT_API_KEY: Use if Qdrant authentication is enabled

# USAGE INSTRUCTIONS

# 1. Copy this file to .env
# 2. Fill in your actual values
# 3. Never commit .env files to version control
# 4. Use different .env files for different environments
# 5. Run the configuration validation script to check consistency:
#    python scripts/validate_configuration.py
