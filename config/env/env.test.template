DASHBOARD_HEALTH_ENDPOINTS='{"Corpus": "http://corpus-service-test:8001/health", "Embedding": "http://embedding-service-test:8000/health", "Inference-Gateway": "http://inference-gateway-test:8002/health", "Orchestrator": "http://127.0.0.1:8000/health", "Qdrant": "http://qdrant-test:6333/healthz"}'

