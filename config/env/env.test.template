# AI Operations Platform (AIOP) Test Environment Configuration Template
# Copy this file to env.test and update the values as needed

CONFIG_SCHEMA_VERSION=2026.02.18
# CORE CONFIGURATION

# Environment
ENV=testing
SERVICE_VERSION=1.0.0
TESTING=1
DEVELOPMENT=0

# DATABASE CONFIGURATION

# PostgreSQL Database - Test Configuration
POSTGRES_USER=testuser
POSTGRES_PASSWORD=test_password_123
POSTGRES_DB=aio-test
POSTGRES_HOST=postgres-test
POSTGRES_PORT=5432
POSTGRES_SSL_MODE=
POSTGRES_MAX_CONNECTIONS=20
POSTGRES_CONNECTION_TIMEOUT=30
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_RECYCLE=3600
DB_POOL_PRE_PING=true

# Database URL for SQLAlchemy (Internal Docker Network)
DATABASE_URL=postgresql+psycopg://testuser:test_password_123@postgres-test:5432/aio-test

# VECTOR DATABASE CONFIGURATION

# Qdrant Vector Database - Test Configuration
QDRANT_HOST=qdrant-test
QDRANT_PORT=6333
QDRANT_URL=http://qdrant-test:6333
QDRANT_API_KEY=
QDRANT_PREFER_GRPC=false
QDRANT_TIMEOUT=10.0
QDRANT_COLLECTION=documents_test
QDRANT_VECTOR_SIZE=384
QDRANT_DISTANCE=COSINE
QDRANT_HNSW_M=16
QDRANT_HNSW_EF_CONSTRUCT=100
QDRANT_HNSW_EF_SEARCH=128
QDRANT_DEFAULT_LIMIT=10
QDRANT_DEFAULT_OFFSET=0

# Inference Gateway Configuration (P1-T1 - Nov 2025)
GATEWAY_HOST=0.0.0.0
GATEWAY_PORT=8002
GATEWAY_DEBUG=true
GATEWAY_ENABLE_CORS=true
GATEWAY_CORS_ORIGINS=*

# Redis Configuration (P2-T4 - Nov 2025)
REDIS_URL=redis://redis-test:6379
REDIS_ENABLED=true
REDIS_MAX_CONNECTIONS=50
REDIS_SOCKET_TIMEOUT=5
REDIS_SOCKET_CONNECT_TIMEOUT=5

# SERVICE URLS CONFIGURATION

# Service URLs - Test Configuration (Internal Docker Network)
CORPUS_SVC_URL=http://corpus-service-test:8001/api/v1
CORPUS_SVC_URL=http://corpus-service-test:8001/api/v1  # Legacy compatibility (use CORPUS_SVC_URL)
EMBEDDING_SERVICE_URL=http://embedding-service-test:8000
LLM_GUARD_SERVICE_URL=http://llm-guard-svc-test:8081

# AUTHENTICATION CONFIGURATION

# JWT Authentication - Test Configuration
JWT_SECRET=test_jwt_secret_for_testing_only_32_chars
# Tool Secrets Encryption Key (for testing only - use strong key in production)
TOOL_SECRETS_KEY=test_tool_secrets_key_minimum_32_characters_for_aes256_encryption
JWT_ALGORITHM=HS256
JWT_ISSUER=ai-operations-platform-test
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# LOGGING CONFIGURATION

# Logging - Test Configuration
LOG_LEVEL=DEBUG
LOG_FORMAT=json
LOG_ENABLE_STRUCTURED=true
LOG_ENABLE_REQUEST_ID=true
LOG_VERBOSE=true

# Secure Logging (v1 - Configuration Flag)
# For testing: disabled to see full request/response details in logs
REDACT_LOGS=false  # Test default: disabled. Production: Set to 'true'
LOG_REDACTION_LEVEL=none  # Test: no redaction. Production: 'partial' or 'full'

# Frontend Logging (Angular)
# Enable verbose request/response logging in the UI for testing
FRONTEND_VERBOSE_LOGGING=true

# OBSERVABILITY CONFIGURATION

# OpenTelemetry - Test Configuration
OTEL_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=aio-test
OTEL_SERVICE_VERSION=1.0.0

# EMBEDDING SERVICE CONFIGURATION

# Embedding Service - Test Configuration
EMBEDDING_HOST=0.0.0.0
EMBEDDING_PORT=8000
EMBEDDING_DEBUG=true
EMBEDDING_ENABLE_CORS=true
EMBEDDING_CORS_ORIGINS=*
EMBEDDING_MODEL=all-minilm-l6-v2
EMBEDDING_DIMENSIONS=384
EMBEDDING_MODEL_CACHE_DIR=/tmp/test_models
EMBEDDING_ENABLE_MODEL_CACHING=false
EMBEDDING_BATCH_SIZE=16
EMBEDDING_CLIENT_TIMEOUT_SECONDS=30
EMBEDDING_CLIENT_MAX_RETRIES=3
EMBEDDING_SERVICE_CLIENT_API_KEY=

# LLM CONFIGURATION

# LLM API Configuration - Test Configuration
LLMAAS_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=test_openai_api_key_for_tests

# MODEL REGISTRY & PRICING CONFIGURATION

# Default pricing for all models (per 1M tokens in USD)
# These defaults are used when model-specific pricing is not set in database
# Set to 0.0 if included in LLMaaS subscription or using local models
PRICING_DEFAULT_INPUT_PER_MILLION=0.0
PRICING_DEFAULT_OUTPUT_PER_MILLION=0.0

# For paid services, set actual costs:
# PRICING_DEFAULT_INPUT_PER_MILLION=0.50
# PRICING_DEFAULT_OUTPUT_PER_MILLION=2.00

# CORPUS SERVICE CONFIGURATION

# Corpus Service - Test Configuration
CORPUS_HOST=0.0.0.0
CORPUS_PORT=8001
CORPUS_DEBUG=true
CORPUS_ENABLE_CORS=true
CORPUS_CORS_ORIGINS=*
CORPUS_EMBEDDING_SERVICE_TOKEN=
CORPUS_DOCUMENTS_PATH=/tmp/test_documents
CORPUS_TEMP_PATH=/tmp/test_tmp
CORPUS_CHUNK_SIZE=1000
CORPUS_CHUNK_OVERLAP=200
CORPUS_MAX_CHUNKS_PER_DOCUMENT=1000

# ORCHESTRATOR SERVICE CONFIGURATION

# Orchestrator Service - Test Configuration
ORCHESTRATOR_HOST=0.0.0.0
ORCHESTRATOR_PORT=8000
ORCHESTRATOR_DEBUG=true
ORCHESTRATOR_ENABLE_CORS=true
ORCHESTRATOR_CORS_ORIGINS=*
ENABLE_TRANSCRIPT_STORAGE=false

# LLM GUARD SERVICE CONFIGURATION

# LLM Guard Service - Test Configuration
LLM_GUARD_ENABLED=false
LLM_GUARD_HOST=0.0.0.0
LLM_GUARD_PORT=8081
LLM_GUARD_DEBUG=true
LLM_GUARD_ENABLE_CORS=true
LLM_GUARD_CORS_ORIGINS=*
LLM_GUARD_FAIL_FAST=false
LLM_GUARD_CACHE_ENABLED=false
LLM_GUARD_CACHE_MAX_SIZE=100
LLM_GUARD_CACHE_TTL_SECONDS=60
LLM_GUARD_MODELS_PATH=/tmp/test_models
LLM_GUARD_PII_MODEL_DIR=distilbert_finetuned_ai4privacy_v2
LLM_GUARD_GIBBERISH_MODEL_DIR=madhurjindal-autonlp-Gibberish-Detector-492513457
LLM_GUARD_LANGUAGE_MODEL_DIR=protectai-xlm-roberta-base-language-detection-onnx
LLM_GUARD_PROMPT_INJECTION_MODEL_DIR=protectai-deberta-v3-small-prompt-injection-v2


