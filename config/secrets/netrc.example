# Example pip / torch index auth for the Python service builds + db-init
# (BuildKit secret id=netrc).
#
# Copy this file to `netrc` in this directory and fill in real values:
#     cp config/secrets/netrc.example config/secrets/netrc
# `netrc` is gitignored. It is mounted to /root/.netrc on a tmpfs only during
# the dependency-install RUN of the orchestrator, corpus_svc, embedding,
# inference-gateway, and llm_guard_svc Dockerfiles — never written to an image
# layer or the build cache. Leave absent for public builds (no auth needed).
#
# One `machine` block per index host. Keep PIP_INDEX_URL / TORCH_INDEX_URL in
# config/make.local.mk WITHOUT embedded credentials — the host below must match
# the host in those URLs.

machine repo.artifactory-gogent.group.echonet
login YOUR_USER
password YOUR_PASSWORD_OR_API_TOKEN

# If your torch index is a different host, add a second block for it:
# machine torch.repo.artifactory-gogent.group.echonet
# login YOUR_USER
# password YOUR_PASSWORD_OR_API_TOKEN
