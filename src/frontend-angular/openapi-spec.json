    "/api/v1/process": {
      "post": {
        "tags": ["orchestrator"],
        "summary": "Process Request",
        "description": "Process a request through the orchestration workflow.\n\nThis endpoint handles the complete orchestration process:\n1. Authentication (via JWT dependency)\n2. Intent parsing\n3. LLM-Guard validation\n4. Context retrieval\n5. Prompt assembly\n6. LLM request processing\n7. Response formatting\n\nArgs:\n    request: The FastAPI request object\n    query: User query or request text\n    request_type: Optional explicit request type (if provided by UI)\n    context: Optional pre-provided context (overrides retrieval)\n    stream: Whether to use streaming response\n    current_user: The authenticated user information (from JWT payload)\n    raw_token: The raw JWT token string from the Authorization header\n    db: Database session\n\nReturns:\n    For non-streaming: JSON response with formatted content\n    For streaming: Streaming response with SSE format",
        "operationId": "process_request_api_v1_process_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/Body_process_request_api_v1_process_post"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/FormattedResponse" }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/HTTPValidationError" }
              }
            }
          }
        },
        "security": [{ "HTTPBearer": [] }]
      }
    },
