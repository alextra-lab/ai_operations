{
  "name": "aio-ui",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "ng lint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky",
    "postinstall": "npm run copy-fonts",
    "copy-fonts": "mkdir -p public/fonts/material-icons public/fonts/roboto public/fonts/plus-jakarta-sans public/fonts/dm-mono && cp -f node_modules/material-icons/iconfont/*.woff* public/fonts/material-icons/ 2>/dev/null || true && cp -f node_modules/typeface-roboto/files/roboto-latin-{300,400,500}.{woff,woff2} public/fonts/roboto/ 2>/dev/null || true && cp -f node_modules/@fontsource/plus-jakarta-sans/files/plus-jakarta-sans-latin-{400,500,600,700}-normal.{woff,woff2} public/fonts/plus-jakarta-sans/ 2>/dev/null || true && cp -f node_modules/@fontsource/dm-mono/files/dm-mono-latin-{400,500}-normal.{woff,woff2} public/fonts/dm-mono/ 2>/dev/null || true",
    "e2e": "ng e2e",
    "cypress:open": "cypress open",
    "cypress:run": "cypress run"
  },
  "private": true,
  "engines": {
    "node": ">=24.0.0"
  },
  "lint-staged": {
    "*.{ts,html,scss,js,json}": [
      "prettier --check"
    ]
  },
  "dependencies": {
    "@angular/animations": "^22.0.0",
    "@angular/cdk": "^22.0.0",
    "@angular/common": "^22.0.0",
    "@angular/compiler": "^22.0.0",
    "@angular/core": "^22.0.0",
    "@angular/forms": "^22.0.0",
    "@angular/material": "^22.0.0",
    "@angular/platform-browser": "^22.0.0",
    "@angular/platform-browser-dynamic": "^22.0.0",
    "@angular/router": "^22.0.0",
    "@angular/service-worker": "^22.0.0",
    "@fontsource/dm-mono": "^5.2.7",
    "@fontsource/plus-jakarta-sans": "^5.2.8",
    "@swimlane/ngx-graph": "^11.0.0",
    "ajv": "^8.17.1",
    "chart.js": "^4.4.4",
    "d3-shape": "^3.2.0",
    "dompurify": "^3.4.7",
    "idb": "^8.0.0",
    "jsonpath-plus": "^10.3.0",
    "katex": "^0.17.0",
    "lucide-angular": "^1.0.0",
    "marked": "^18.0.4",
    "material-icons": "^1.13.14",
    "mermaid": "^11.15.0",
    "ng2-charts": "^10.0.0",
    "ngx-markdown": "^21.0.1",
    "primeicons": "^7.0.0",
    "primeng": "^21.1.1",
    "prismjs": "^1.29.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "typeface-roboto": "^1.1.13",
    "zone.js": "~0.16.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^21.1.2",
    "@angular/cli": "^22.0.0",
    "@angular/compiler-cli": "^22.0.0",
    "@cypress/schematic": "^4.1.3",
    "@openapitools/openapi-generator-cli": "^2.24.0",
    "@testing-library/angular": "^17.4.0",
    "@testing-library/cypress": "^10.1.0",
    "@types/jest": "^30.0.0",
    "angular-eslint": "22.0.0",
    "autoprefixer": "^10.4.21",
    "baseline-browser-mapping": "^2.8.9",
    "cypress": "^15.3.0",
    "eslint": "^9.35.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "husky": "^9.1.7",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "jest-preset-angular": "^15.0.3",
    "lint-staged": "^16.2.3",
    "postcss": "^8.5.6",
    "prettier": "^3.6.2",
    "prettier-plugin-organize-imports": "^4.3.0",
    "tailwindcss": "^3.4.18",
    "ts-jest": "^29.4.5",
    "ts-node": "^10.9.2",
    "typescript": "~5.9.0",
    "typescript-eslint": "8.40.0",
    "web-streams-polyfill": "^4.2.0",
    "webpack-dev-server": "^5.2.4"
  },
  "overrides": {
    "glob": "^10.3.10",
    "critters": "npm:beasties@^0.3.5",
    "webpack-dev-server": "^5.2.4",
    "uuid": "^11.1.1",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "shell-quote": "^1.8.4",
    "jest-preset-angular": {
      "@angular/animations": "^21.1.2",
      "@angular/common": "^21.1.2",
      "@angular/compiler": "^21.1.2",
      "@angular/compiler-cli": "^21.1.2",
      "@angular/core": "^21.1.2",
      "@angular/forms": "^21.1.2",
      "@angular/platform-browser": "^21.1.2",
      "@angular/platform-browser-dynamic": "^21.1.2",
      "@angular/router": "^21.1.2"
    },
    "@swimlane/ngx-graph": {
      "@angular/animations": "^21.1.2",
      "@angular/cdk": "^21.1.2",
      "@angular/common": "^21.1.2",
      "@angular/core": "^21.1.2",
      "@angular/platform-browser": "^21.1.2"
    }
  }
}
