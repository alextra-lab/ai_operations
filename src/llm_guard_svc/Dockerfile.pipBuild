# Stage 1: Build dependencies
FROM python:3.14-slim AS builder
WORKDIR /app

# Install build tools with full compiler support for spacy-pkuseg
RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential g++ git cmake \
    && rm -rf /var/lib/apt/lists/*

# Install Python dependencies
COPY llm_guard_svc/requirements.txt .

RUN pip wheel --no-cache-dir --wheel-dir /app/wheels -r requirements.txt \
    && pip wheel --no-cache-dir --wheel-dir /app/wheels "transformers[torch]" --extra-index-url https://download.pytorch.org/whl/cpu

# Stage 2: Runtime
FROM python:3.14-slim
WORKDIR /app

# Set environment variables
ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1 \
    PORT=8081 \
    HF_HOME=/app/models \
    TRANSFORMERS_OFFLINE=1 \
    HF_HUB_OFFLINE=1 \
    PYTHONPATH="/app"

# Runtime dependencies (add the necessary build tools for wheels that need compilation)
RUN apt-get update && apt-get install -y --no-install-recommends \
    curl ca-certificates g++ build-essential \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/*

# Create models directory where external models will be mounted
RUN mkdir -p /app/models

# Copy wheels from builder stage
COPY --from=builder /app/wheels /app/wheels
COPY --from=builder /app/requirements.txt .

# Install dependencies
RUN pip install --no-cache-dir --no-index --find-links=/app/wheels -r requirements.txt \
    && pip install --no-cache-dir --no-index --find-links=/app/wheels "transformers[torch]" \
    # Explicitly install/re-install llm-guard and optimum with extras to ensure they are correctly set up
    && pip install --no-cache-dir "llm-guard[onnxruntime-cpu]>=0.3.16" "optimum[onnxruntime]>=1.25.2" \
    && pip install --no-cache-dir --upgrade bitsandbytes \
    && rm -rf /app/wheels

# Download and pre-install spacy-pkuseg and SpaCy models to avoid runtime errors (both English and Chinese)
RUN python -m spacy download en_core_web_sm && \
    # Install Chinese model using the correct method (via direct download)
    pip install --no-cache-dir https://github.com/explosion/spacy-models/releases/download/zh_core_web_sm-3.8.0/zh_core_web_sm-3.8.0-py3-none-any.whl && \
    pip install --no-cache-dir spacy-pkuseg

# Create a non-root user
RUN groupadd -r guarduser && useradd -r -g guarduser guarduser

# Copy llm_guard_svc service code
COPY llm_guard_svc/app /app/app

# Copy shared code
COPY shared /app/shared

# Make sure models directory is accessible
RUN chown -R guarduser:guarduser /app

# Switch to non-root user
USER guarduser

# Health check
HEALTHCHECK --interval=30s --timeout=5s --start-period=5s --retries=3 \
    CMD curl -f http://localhost:${PORT}/health || exit 1

# Expose port
EXPOSE ${PORT}

# Start the app using uvicorn
CMD ["uvicorn", "app.main:app", "--host", "0.0.0.0", "--port", "8081"]
