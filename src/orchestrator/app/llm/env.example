# Example environment configuration for AI Operations Platform

# Model Implementation Mappings
# These variables map intent-aligned model types to actual LLM implementations
MODEL_IMPLEMENTATION_QUERY=gpt-4.1-nano
MODEL_IMPLEMENTATION_RULE_GENERATION=gpt-4.1-mini
MODEL_IMPLEMENTATION_SUMMARIZATION=gpt-4.1-mini
MODEL_IMPLEMENTATION_ENRICHMENT=gpt-4.1-mini

# Model Temperature Settings
# Controls randomness in generation (higher = more creative/varied, lower = more consistent/focused)
MODEL_TEMPERATURE_QUERY=0.7
MODEL_TEMPERATURE_RULE_GENERATION=0.2
MODEL_TEMPERATURE_SUMMARIZATION=0.5
MODEL_TEMPERATURE_ENRICHMENT=0.6

# Model Max Token Settings
# Controls maximum length of generated responses
MODEL_MAX_TOKENS_QUERY=4096
MODEL_MAX_TOKENS_RULE_GENERATION=8192
MODEL_MAX_TOKENS_SUMMARIZATION=6144
MODEL_MAX_TOKENS_ENRICHMENT=8192

# Model Fallback Mappings
# Controls which model to try if the primary model fails
MODEL_FALLBACK_QUERY=SUMMARIZATION
MODEL_FALLBACK_RULE_GENERATION=ENRICHMENT
MODEL_FALLBACK_SUMMARIZATION=QUERY
MODEL_FALLBACK_ENRICHMENT=RULE_GENERATION

# LLMaaS Endpoint Configuration
LLMAAS_BASE_URL=https://api.llm-service.example.com/v1
LLMAAS_API_KEY=your-api-key-here
REQUEST_TIMEOUT=300  # Seconds

# For backward compatibility (legacy environment variables)
# These are maintained for systems that haven't been updated yet
INTENT_MODEL_QUERY=QUERY
INTENT_MODEL_RULE_GENERATION=RULE_GENERATION
INTENT_MODEL_SUMMARIZATION=SUMMARIZATION
INTENT_MODEL_ENRICHMENT=ENRICHMENT

INTENT_TEMP_QUERY=0.7
INTENT_TEMP_RULE_GENERATION=0.2
INTENT_TEMP_SUMMARIZATION=0.5
INTENT_TEMP_ENRICHMENT=0.6

INTENT_TOKENS_QUERY=4096
INTENT_TOKENS_RULE_GENERATION=8192
INTENT_TOKENS_SUMMARIZATION=6144
INTENT_TOKENS_ENRICHMENT=8192

INTENT_FALLBACK_QUERY=SUMMARIZATION
INTENT_FALLBACK_RULE_GENERATION=ENRICHMENT
INTENT_FALLBACK_SUMMARIZATION=QUERY
INTENT_FALLBACK_ENRICHMENT=RULE_GENERATION
